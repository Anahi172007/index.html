<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mi Empresa</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- CSS personalizado -->
    <link rel="stylesheet" href="css/style.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand" href="#">Mi Empresa</a>

                <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#inicio">Inicio</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#nosotros">Quiénes Somos</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#servicios">Servicios</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="#contacto">Contacto</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- MAIN -->
    <main>

        <!-- INICIO -->
        <section id="inicio" class="hero text-center text-white d-flex align-items-center">
            <div class="container">
                <h1 class="display-4">Bienvenidos a Mi Empresa</h1>
                <p class="lead">
                    Ofrecemos soluciones innovadoras y de calidad.
                </p>

                <a href="#servicios" class="btn btn-warning btn-lg m-2">
                    Ver Servicios
                </a>

                <a href="#contacto" class="btn btn-light btn-lg m-2">
                    Contáctanos
                </a>
            </div>
        </section>

        <!-- QUIENES SOMOS -->
        <section id="nosotros" class="container py-5">
            <h2 class="text-center mb-4">Quiénes Somos</h2>

            <div class="row align-items-center">

                <article class="col-md-6">
                    <img src="img/nosotros.jpg"
                        alt="Nosotros"
                        class="img-fluid rounded shadow">
                </article>

                <article class="col-md-6">
                    <h3>Nuestra Historia</h3>
                    <p>
                        Somos una empresa comprometida con la calidad,
                        innovación y satisfacción de nuestros clientes.
                    </p>

                    <p>
                        Nuestro objetivo es brindar servicios que generen
                        valor y confianza.
                    </p>
                </article>

            </div>
        </section>

        <!-- SERVICIOS -->
        <section id="servicios" class="bg-light py-5">

            <div class="container">

                <h2 class="text-center mb-5">Nuestros Servicios</h2>

                <div class="row">

                    <article class="col-md-4 mb-4">
                        <div class="card shadow h-100">
                            <img src="img/servicio1.jpg"
                                class="card-img-top"
                                alt="Servicio 1">

                            <div class="card-body">
                                <h5 class="card-title">
                                    Servicio 1
                                </h5>

                                <p class="card-text">
                                    Descripción del servicio ofrecido.
                                </p>

                                <a href="#" class="btn btn-primary">
                                    Más información
                                </a>
                            </div>
                        </div>
                    </article>

                    <article class="col-md-4 mb-4">
                        <div class="card shadow h-100">
                            <img src="img/servicio2.jpg"
                                class="card-img-top"
                                alt="Servicio 2">

                            <div class="card-body">
                                <h5 class="card-title">
                                    Servicio 2
                                </h5>

                                <p class="card-text">
                                    Descripción del servicio ofrecido.
                                </p>

                                <a href="#" class="btn btn-primary">
                                    Más información
                                </a>
                            </div>
                        </div>
                    </article>

                    <article class="col-md-4 mb-4">
                        <div class="card shadow h-100">
                            <img src="img/servicio3.jpg"
                                class="card-img-top"
                                alt="Servicio 3">

                            <div class="card-body">
                                <h5 class="card-title">
                                    Servicio 3
                                </h5>

                                <p class="card-text">
                                    Descripción del servicio ofrecido.
                                </p>

                                <a href="#" class="btn btn-primary">
                                    Más información
                                </a>
                            </div>
                        </div>
                    </article>

                </div>
            </div>
        </section>

        <!-- ASIDE -->
        <aside class="container text-center py-5">
            <h3>Síguenos en nuestras redes</h3>

            <a href="#" class="btn btn-outline-primary m-2">
                Facebook
            </a>

            <a href="#" class="btn btn-outline-danger m-2">
                Instagram
            </a>

            <a href="#" class="btn btn-outline-success m-2">
                WhatsApp
            </a>
        </aside>

        <!-- CONTACTO -->
        <section id="contacto" class="container py-5">

            <h2 class="text-center mb-4">
                Contacto
            </h2>

            <div class="row justify-content-center">

                <div class="col-md-8">

                    <form class="shadow p-4 rounded bg-light">

                        <div class="mb-3">
                            <label class="form-label">
                                Nombre
                            </label>

                            <input type="text"
                                class="form-control"
                                placeholder="Ingrese su nombre">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Correo Electrónico
                            </label>

                            <input type="email"
                                class="form-control"
                                placeholder="correo@ejemplo.com">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Asunto
                            </label>

                            <input type="text"
                                class="form-control">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">
                                Mensaje
                            </label>

                            <textarea
                                class="form-control"
                                rows="5"></textarea>
                        </div>

                        <button type="submit"
                            class="btn btn-primary">
                            Enviar Mensaje
                        </button>

                    </form>

                </div>

            </div>

        </section>

    </main>

    <!-- FOOTER -->
    <footer class="bg-dark text-white text-center p-3">
        <p>
            © 2025 Mi Empresa - Todos los derechos reservados
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

